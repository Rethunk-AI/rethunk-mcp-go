{
  "author": "Damon Blais <damon@rethunk.tech>",
  "description": "A Model Context Protocol (MCP) server that provides Go language tools for LLMs to analyze, test, and format Go code",
  "engines": {
    "node": ">=20.12.0",
    "bun": ">=1.3.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm",
    "ai",
    "golang",
    "go",
    "static-analysis",
    "code-tools"
  ],
  "license": "MIT",
  "main": "build/index.js",
  "name": "mcp-golang",
  "packageManager": "bun@1.3.12",
  "type": "module",
  "version": "1.0.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "@hono/node-server": "^1.19.14",
    "express-rate-limit": "^8.3.2",
    "hono": "^4.12.14",
    "vite": "^8.0.5"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf build",
    "dev": "tsc -w",
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "prebuild": "bun run clean",
    "start": "node build/index.js",
    "inspector": "mcp-inspector",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  }
}
