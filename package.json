{
  "author": "Damon Blais <damon@rethunk.tech>",
  "description": "A Model Context Protocol (MCP) server that provides Go language tools for LLMs to analyze, test, and format Go code",
  "engines": {
    "node": ">=20.12.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm",
    "ai",
    "golang",
    "go",
    "static-analysis",
    "code-tools"
  ],
  "license": "MIT",
  "main": "build/index.js",
  "name": "mcp-golang",
  "packageManager": "yarn@4.7.0",
  "type": "module",
  "version": "1.0.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf build",
    "dev": "tsc -w",
    "lint": "biome ci .",
    "lint:fix": "biome check --write .",
    "prebuild": "yarn clean",
    "start": "node build/index.js",
    "inspector": "mcp-inspector",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  }
}
