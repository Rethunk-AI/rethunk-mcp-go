{
  "author": "Damon Blais <damon@rethunk.tech>",
  "description": "A Model Context Protocol (MCP) server that provides Go language tools for LLMs to analyze, test, and format Go code",
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm",
    "ai",
    "golang",
    "go",
    "static-analysis",
    "code-tools"
  ],
  "license": "MIT",
  "main": "build/index.js",
  "name": "mcp-golang",
  "packageManager": "yarn@4.7.0",
  "type": "module",
  "version": "1.0.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "resolutions": {
    "eslint": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "typescript-eslint": "^8.56.1"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf build",
    "dev": "tsc -w",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prebuild": "yarn clean",
    "start": "node build/index.js",
    "inspector": "mcp-inspector",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  }
}
